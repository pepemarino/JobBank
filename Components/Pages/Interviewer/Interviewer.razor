@page "/Interviewer"
@inherits ViewModelBase<IInterviewerViewModel>
@rendermode InteractiveServer
@attribute [Authorize]

@attribute [Authorize]
@if (!_isHydrated)
{
    <div class="loading-shell">
        Loading interview…
    </div>
}
else
{
@if (ViewModel.IsProcessing)
{
    <div class="modal fade show" style="display:block; background-color: rgba(0,0,0,0.5);" role="dialog">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Processing</h5>
                </div>
                <div class="modal-body">

                    <div class="text-center p-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p>Processing your response...</p>
                    </div>

                </div>
            </div>
        </div>
    </div>
}

<div class="d-flex justify-content-between align-items-center my-4">
    <div>
        <h1 class="display-5 mb-0">@ViewModel.JobTitle</h1>
        <p class="text-muted fs-4">@ViewModel.CompanyName</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@($"/jobposts/edit?id={JobPostId}")" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Back to Edit
        </a>
        <a href="/jobposts" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row mb-4">
        <div class="container-fluid px-4" ">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header">
            <div>@ViewModel.Title</div>
        </div>
        <div class="card-body">
            <div><p style="white-space: pre-wrap;">@ViewModel.JobDescription</p></div>
        </div>

        <div class="card-footer text-muted">
            Last updated
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="content">
            <div class="card-header">
                <h5 class="card-title">@ViewModel.Title</h5>
            </div>
            <div class="text-body">
                @if (!string.IsNullOrEmpty(ViewModel.ResponseMessage))
                {
                    <div class="alert alert-success" role="alert">
                        @ViewModel.ResponseMessage
                    </div>
                }
                        @if (ViewModel.IsJobDescriptionAvailable)
                        {
                    <div id="chat-container" style="height: 500px; overflow-y: auto; scroll-behavior: smooth;">
                        @foreach (var chat in ViewModel.History)
                        {
                            <div class="d-flex @(chat.Role == "User" ? "justify-content-end" : "justify-content-start") mb-2">
                                <div class="p-3 rounded-3 @(chat.Role == "User" ? "bg-primary text-white" : "bg-light border")"
                                     style="max-width: 80%;">
                                    <strong>@chat.Role:</strong>
                                    <div>@chat.Content</div>
                                    <small class="opacity-50">@chat.Timestamp.ToString("t")</small>
                                </div>
                            </div>
                        }
                    </div>

                            <div class="mb-3">
                                <strong>@ViewModel.QuestionProgressCounter</strong> @ViewModel.InterviewAgentQuestion
                            </div>
                <input type="hidden" id="JobPostId" value="@ViewModel.JobPostId" />
                <div class="mb-3">
                    <label for="interviewUserAnswer" class="form-label fw-bold">Your Response</label>
                    <InputTextArea id="interviewUserAnswer" 
                                   @bind-Value="ViewModel.InterviewAnswer" 
                                               class="form-control"
                                               disabled="@(ViewModel.IsInterviewCompleted)" />
                                <button class="btn btn-sm btn-primary interview-send-response"
                                        @onclick="ViewModel.ProcessAnswerAsync"
                                        style="margin: 1rem;"
                                        disabled="@(ViewModel.IsInterviewCompleted)">
                                    @if (ViewModel.IsInterviewCompleted)
                                    {
                                        <i class="bi bi-lock-fill me-2"></i> @* Visual hint *@
                                    }
                                    else
                                    {
                                        <i class="bi bi-save me-2"></i>
                                    }
                                    Click to Answer
                                </button>
                </div>
                        }
            </div>
        </div>
    </div>
</div>
</div>
}

@code {
    // Capture the query parameter JobPostId and pass it to the ViewModel
    [Parameter]
    [SupplyParameterFromQuery]
    public int JobPostId { get; set; }

    protected override Task OnInitializedAsync() => Task.CompletedTask;

    private bool _restored = false;
    private bool _isHydrated = false;


    /// <summary>
    /// For S-SSR JavaScript interop is not avalable the first time it renders,
    /// so we need to wait until the first render to restore the state from the browser.
    /// This is by design, hence need to wait until the VM is hydrated.
    /// </summary>
    /// <param name="firstRender"></param>
    /// <returns></returns>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
    {
            _isHydrated = true;             // this is the second time around
            ViewModel.Reset();

        ViewModel.JobPostId = JobPostId;

            await ViewModel.RestoreFromBrowserAsync();
        await ViewModel.InitializeAsync();

            StateHasChanged();
        }
    }
}
